---
import '../styles/global.css'; 
import rawQsoData from '../data/qso.json';
import SEO from '../components/SEO.astro';

interface QsoRecord {
  callsign: string;
  band: string;
  mode: string;
  time_on: string;
  rst_sent: string;
  rst_rcvd: string;
  country: string;
  grid: string;
}

// 1. 排序逻辑
const allSortedData = (rawQsoData as QsoRecord[]).sort((a, b) => {
  return new Date(b.time_on).getTime() - new Date(a.time_on).getTime();
});

// 2. 分页参数
const pageSize = 25;
const totalHits = allSortedData.length;
const { searchParams } = Astro.url;
const currentPage = Math.max(1, parseInt(searchParams.get('page') || '1'));
const totalPages = Math.ceil(totalHits / pageSize);

// 3. 截取当前页数据
const qsoData = allSortedData.slice((currentPage - 1) * pageSize, currentPage * pageSize);

// 4. 统计
const uniqueCallsigns = totalHits > 0 
  ? [...new Set(allSortedData.map(q => q.callsign))].length 
  : 0;

// 预处理分页字符串，避免在模板里写复杂的逻辑
const pageStatus = totalHits > 0 ? "PAGE: " + currentPage + " / " + totalPages : "Standby";
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <SEO 
      title="QSO LOG" 
      description="BA8BLK 电台实时通联日志监控中心。展示最新的 FT8/数字模式通联记录、信号强度及全球通联分布数据。"
      keywords="BA8BLK LOG, QSO实时日志, FT8通联, 业余无线电监控, 电波传播, 四川HAM"
    />
</head>
<body class="bg-[#F8F9FA] min-h-screen m-0 font-sans text-gray-900 selection:bg-[#38A169] selection:text-white">

  <div class="max-w-4xl mx-auto px-4 relative">
    <div class="absolute top-8 left-4 md:left-0">
      <a href="/" class="text-[11px] font-mono text-gray-400 hover:text-[#38A169] transition-colors flex items-center gap-2 group uppercase tracking-widest">
        <span class="group-hover:-translate-x-1 transition-transform inline-block">←</span>
        <span>Return_to_Console 返回工作台</span>
      </a>
    </div>
  </div>

  <div class="max-w-4xl mx-auto pt-24 pb-12 px-4">
    
    <div class="mb-8">
      <h1 class="text-2xl font-bold tracking-widest uppercase mb-1 flex items-center gap-3">
        <span>通联日志</span>
        <span class="text-gray-300 font-light">/</span> 
        <span class="text-lg text-gray-500 font-mono mt-1">QSO LOG</span>
      </h1>
      <p class="text-sm text-gray-500 leading-relaxed">
        由电台室自动同步的近期通联记录。最近 <strong class="text-gray-800">{totalHits}</strong> 次有效解码。
      </p>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm mb-6 flex justify-between items-center">
      <div>
        <div class="text-[10px] md:text-xs font-mono text-gray-400 mb-1 uppercase tracking-wide">
          Cumulative_Hits // 累计解码
        </div>
        <div class="text-3xl font-black text-gray-800">{totalHits}</div>
      </div>
      <div class="text-right">
        <div class="text-[10px] md:text-xs font-mono text-gray-400 mb-1 uppercase tracking-wide">
          Unique_Callsigns // 独立呼号
        </div>
        <div class="text-3xl font-black text-gray-800">{uniqueCallsigns}</div>
      </div>
    </div>

    <div class="flex justify-between items-center text-[10px] font-mono text-[#38A169] mb-4 px-2 uppercase tracking-wider">
      <div class="flex items-center gap-2">
        <span class={totalHits > 0 ? "animate-pulse" : "opacity-50"}>●</span>
        <span>Terminal_Monitor_Active</span>
      </div>
      <span class="opacity-60 text-gray-400">
        {pageStatus}
      </span>
    </div>

    <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
      {totalHits === 0 ? (
        <div class="text-center py-12 bg-gray-50">
          <div class="text-gray-400 font-mono text-sm">NO_SIGNAL_DETECTED</div>
        </div>
      ) : (
        <>
          <div class="overflow-x-auto">
            <table class="w-full text-left font-mono text-xs md:text-sm whitespace-nowrap">
              <thead class="bg-gray-50 text-gray-500 border-b border-gray-200 tracking-wider">
                <tr>
                  <th class="px-4 py-3 font-normal align-top">
                    <div class="text-[10px] uppercase">UTC Time</div>
                    <div class="text-[11px] text-gray-500 mt-1 font-sans tracking-normal">通联时间</div>
                  </th>
                  <th class="px-4 py-3 font-normal align-top">
                    <div class="text-[10px] uppercase">Callsign</div>
                    <div class="text-[11px] text-gray-500 mt-1 font-sans tracking-normal">电台呼号</div>
                  </th>
                  <th class="px-4 py-3 font-normal align-top">
                    <div class="text-[10px] uppercase">Band / Mode</div>
                    <div class="text-[11px] text-gray-500 mt-1 font-sans tracking-normal">频段 / 模式</div>
                  </th>
                  <th class="px-4 py-3 font-normal align-top">
                    <div class="text-[10px] uppercase">Report (TX/RX)</div>
                    <div class="text-[11px] text-gray-500 mt-1 font-sans tracking-normal">信号报告 (发/收)</div>
                  </th>
                  <th class="px-4 py-3 font-normal align-top">
                    <div class="text-[10px] uppercase">Location [Grid]</div>
                    <div class="text-[11px] text-gray-500 mt-1 font-sans tracking-normal">位置 [网格]</div>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100 text-gray-600">
                {qsoData.map((qso) => (
                  <tr class="hover:bg-gray-50 transition-colors group">
                    <td class="px-4 py-2.5 text-gray-400">{qso.time_on}</td>
                    <td class="px-4 py-2.5 font-bold text-gray-800 group-hover:text-[#38A169] transition-colors">{qso.callsign}</td>
                    <td class="px-4 py-2.5">{qso.band} <span class="text-gray-400 ml-1">{qso.mode}</span></td>
                    <td class="px-4 py-2.5 font-medium text-[#38A169]">
                      <span class="text-gray-400 text-[10px] font-normal">TX:</span> {qso.rst_sent} 
                      <span class="text-gray-400 text-[10px] font-normal ml-2">RX:</span> {qso.rst_rcvd}
                    </td>
                    <td class="px-4 py-2.5 text-gray-500">
                      {qso.country} <span class="text-gray-400 text-[10px] ml-1">[{qso.grid || '---'}]</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          {totalPages > 1 && (
            <div class="px-4 py-4 bg-gray-50 border-t border-gray-200 flex justify-between items-center font-mono text-[11px]">
              <div class="text-gray-400 uppercase tracking-widest">
                Index: <span class="text-gray-800">{(currentPage - 1) * pageSize + 1} - {Math.min(currentPage * pageSize, totalHits)}</span> / {totalHits}
              </div>
              <div class="flex gap-6">
                {currentPage > 1 ? (
                  <a href={"?page=" + (currentPage - 1)} class="text-[#38A169] hover:font-bold transition-all uppercase tracking-widest">
                    [ PREV_PAGE ]
                  </a>
                ) : (
                  <span class="text-gray-200 cursor-not-allowed uppercase tracking-widest">[ PREV_PAGE ]</span>
                )}

                {currentPage < totalPages ? (
                  <a href={"?page=" + (currentPage + 1)} class="text-[#38A169] hover:font-bold transition-all uppercase tracking-widest">
                    [ NEXT_PAGE ]
                  </a>
                ) : (
                  <span class="text-gray-200 cursor-not-allowed uppercase tracking-widest">[ NEXT_PAGE ]</span>
                )}
              </div>
            </div>
          )}
        </>
      )}
    </div>

  </div>
</body>
</html>