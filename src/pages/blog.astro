---
import '../styles/global.css';
import { getCollection } from 'astro:content';
const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LOGS // BA8BLK</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" />
</head>
<body class="bg-[#fbfbfb] text-[#171717] antialiased font-['JetBrains_Mono','Noto_Sans_SC']">
    
    <main class="max-w-3xl mx-auto px-6 py-24">
        <header class="mb-20">
            <div class="flex items-end justify-between border-b border-black/5 pb-6">
                <div>
                    <h1 class="text-3xl font-black tracking-tighter text-black uppercase">Archive</h1>
                    <p class="text-[10px] text-[#059669] font-bold tracking-[0.3em] mt-2">BA8BLK's Blog</p>
                </div>
                <a href="/"   class="text-[11px] font-['JetBrains_Mono'] text-gray-400 hover:text-[#52ff00] transition-colors flex items-center gap-2 group uppercase tracking-widest">
                <span class="group-hover:-translate-x-1 transition-transform inline-block">←</span>
                <span>Return_to_Console 返回工作台</span>
                </a>
            </div>
        </header>

        <div class="space-y-12">
            {sortedPosts.map(post => (
                <article class="group">
                    <a href={`/blog/${post.slug}`} class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-10">
                        <time class="font-mono text-base font-medium text-black/40 shrink-0 min-w-[120px] tracking-tight">
    {post.data.pubDate.toLocaleDateString('zh-CN', {year: 'numeric', month: '2-digit', day: '2-digit'}).replace(/\//g, '-')}
                        </time>
                        
                        <div class="flex flex-col">
                            <h2 class="text-xl font-bold text-[#171717] group-hover:text-[#059669] group-hover:underline decoration-2 underline-offset-8 transition-all leading-snug">
                                {post.data.title}
                            </h2>
                            {post.data.description && (
                                <p class="mt-2 text-sm text-black/50 font-normal leading-relaxed">
                                    {post.data.description}
                                </p>
                            )}
                        </div>
                    </a>
                </article>
            ))}
        </div>
    </main>

    <footer class="py-24 text-center opacity-10 text-[20px] tracking-[0.25em] uppercase text-black">
        73 de ba8blk sk
    </footer>
</body>
</html>