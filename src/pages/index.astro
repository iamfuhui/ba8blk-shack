---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
---
<head>
    <SEO 
      title="Chinese Amateur Radio Station" 
      description="BA8BLK 业余无线电台控制中心。提供实时通联日志 (QSO)、卡片确认状态查询 (QSL) 以及电波信号博客。"
    />

    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;400;800&display=swap" rel="stylesheet">
    <style>
        /* 1. 模拟 CRT 屏幕颗粒与扫描线 */
        .crt-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
            background-size: 100% 3px, 3px 100%;
            pointer-events: none;
            z-index: 100;
        }

        /* 2. 核心闪烁动画：模拟电流不稳和荧光粉余辉 */
        @keyframes crt-flicker {
            0% { opacity: 0.98; filter: brightness(1); }
            5% { opacity: 0.95; filter: brightness(1.05); }
            10% { opacity: 0.99; }
            15% { opacity: 0.96; }
            50% { opacity: 1; }
            80% { opacity: 0.98; }
            100% { opacity: 1; }
        }

        /* 3. 文字扫描重影动画 */
        @keyframes text-scan {
            0%, 100% { text-shadow: 0 0 10px rgba(82, 255, 0, 0.5); }
            33% { text-shadow: 2px 0 2px rgba(255,0,0,0.1), -2px 0 2px rgba(0,0,255,0.1), 0 0 15px rgba(82, 255, 0, 0.6); }
            66% { text-shadow: -1px 0 1px rgba(255,0,0,0.1), 1px 0 1px rgba(0,0,255,0.1), 0 0 12px rgba(82, 255, 0, 0.4); }
        }

        .crt-flicker-effect {
            animation: crt-flicker 6.8s infinite;
        }

        .glow-text {
            animation: text-scan 2s infinite;
        }

        .grid-bg {
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: 0.15;
            background-image: 
                linear-gradient(rgba(82, 255, 0, 0.1) 1px, transparent 1px), 
                linear-gradient(90deg, rgba(82, 255, 0, 0.1) 1px, transparent 1px);
            background-size: 32px 32px;
        }
    </style>
</head>
<body class="bg-[#0a0a0c] text-[#52ff00] min-h-screen flex flex-col items-center justify-center m-0 overflow-hidden font-['JetBrains_Mono'] crt-flicker-effect">
    
    <div class="crt-overlay"></div>
    <div class="grid-bg"></div>

    <main class="relative z-10 flex flex-col items-center w-full px-6 md:px-4">
        
        <p class="text-[10px] sm:text-xs md:text-sm tracking-[0.5em] md:tracking-[0.8em] mb-4 opacity-70 ml-[0.5em] md:ml-[0.8em] uppercase font-bold text-center">
            Chinese Amateur Radio Station
        </p>
        
        <h1 class="text-[20vw] sm:text-[18vw] md:text-[12rem] lg:text-[14rem] font-black leading-none tracking-tighter glow-text select-none mb-10 md:mb-14">
            BA8BLK
        </h1>

        <div class="flex flex-col gap-3 w-full max-w-md mx-auto">
            {[
                { id: "SYS_01", en: "QSO LOG", zh: "通联日志", href: "/qso" },
                { id: "SYS_02", en: "QSL CHECK", zh: "卡片查询", href: "/qsl" },
                { id: "SYS_03", en: "SIGNAL BLOG", zh: "电波博客", href: "/blog" },
                { id: "SYS_04", en: "STATION INFO", zh: "台站资料", href: "/about" },
                { id: "EXT_05", en: "QRZ.COM", zh: "国际档案", href: "https://www.qrz.com/db/BA8BLK", target: "_blank" }
            ].map((item) => (
                <a 
                    href={item.href} 
                    target={item.target || "_self"}
                    class="group relative flex items-center justify-between px-5 py-3 md:py-4 border border-[#52ff00]/30 bg-black/40 backdrop-blur-sm transition-all duration-300 hover:bg-[#52ff00]/10 hover:border-[#52ff00] hover:shadow-[0_0_15px_rgba(82,255,0,0.3)] overflow-hidden"
                >
                    <div class="flex items-center">
                        <span class="absolute left-3 opacity-0 group-hover:opacity-100 transition-opacity font-bold">></span>
                        
                        <div class="flex items-center gap-3 ml-4 md:ml-2 transition-transform group-hover:translate-x-4">
                            <span class="text-[10px] opacity-50 tracking-widest hidden sm:block">[{item.id}]</span>
                            <span class="text-sm md:text-base font-bold tracking-[0.2em]">{item.en}</span>
                        </div>
                    </div>
                    
                    <span class="text-[10px] md:text-[11px] opacity-40 tracking-widest font-sans transition-opacity group-hover:opacity-80">
                        // {item.zh}
                    </span>
                </a>
            ))}
        </div>

    </main>

    <div class="fixed bottom-6 left-6 right-6 md:bottom-8 md:left-8 md:right-8 flex justify-between items-center text-[9px] md:text-[10px] opacity-40 tracking-[0.2em] md:tracking-[0.3em] font-light">
        <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-[#52ff00] rounded-full animate-pulse shadow-[0_0_8px_rgba(82,255,0,0.8)]"></div>
            RX_READY
        </div>
        <div class="text-right">
            GRID: OM21EC <span class="hidden sm:inline">// 14.270 MHZ</span>
        </div>
    </div>

</body>
</html>