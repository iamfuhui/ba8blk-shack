---
// BA8BLK Radio Shack - Modern Precision "Live" Edition
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <title>BA8BLK // LIVE CONSOLE</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;400;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --accent-green: #52ff00; 
            --accent-red: #ff003c;
            --bg-black: #0a0a0c;
            --line-color: rgba(82, 255, 0, 0.12);
        }
        
        body {
            background-color: var(--bg-black);
            color: var(--accent-green);
            margin: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            font-family: 'JetBrains Mono', monospace;
            overflow: hidden;
            background-image: 
                linear-gradient(var(--line-color) 1px, transparent 1px),
                linear-gradient(90deg, var(--line-color) 1px, transparent 1px);
            background-size: 40px 40px;
        }

        /* 屏幕扫描线干扰 */
        body::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(to bottom, transparent 50%, rgba(0,0,0,0.05) 50%);
            background-size: 100% 4px;
            z-index: 5;
            pointer-events: none;
        }

        .container { 
            text-align: center; 
            z-index: 10; 
            border: 1px solid var(--line-color);
            padding: 50px 80px;
            position: relative;
            background-color: rgba(10, 10, 12, 0.9);
            backdrop-filter: blur(10px);
            box-shadow: 0 0 40px rgba(0,0,0,0.5);
        }

        /* 装饰角标 */
        .corner {
            position: absolute;
            width: 15px;
            height: 15px;
            border: 2px solid var(--accent-green);
        }
        .top-left { top: -2px; left: -2px; border-right: none; border-bottom: none; }
        .top-right { top: -2px; right: -2px; border-left: none; border-bottom: none; }
        .bottom-left { bottom: -2px; left: -2px; border-right: none; border-top: none; }
        .bottom-right { bottom: -2px; right: -2px; border-left: none; border-top: none; }
        
        h1 { 
            font-size: clamp(3rem, 12vw, 8.5rem);
            font-weight: 800; 
            margin: 0;
            letter-spacing: -3px;
            line-height: 1;
            filter: drop-shadow(0 0 15px rgba(82, 255, 0, 0.3));
        }
        
        .sub-header {
            font-size: 0.75rem;
            letter-spacing: 5px;
            margin-bottom: 12px;
            color: var(--accent-green);
            opacity: 0.7;
            text-transform: uppercase;
        }

        /* 底部数据流布局 */
        .data-stream {
            margin-top: 40px;
            font-size: 0.75rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-top: 1px solid var(--line-color);
            padding-top: 15px;
            color: rgba(82, 255, 0, 0.6);
            min-width: 500px;
        }

        /* ON AIR 闪烁灯 */
        .status-box {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--accent-red);
            font-weight: bold;
        }

        .tx-dot {
            width: 8px;
            height: 8px;
            background-color: var(--accent-red);
            border-radius: 50%;
            box-shadow: 0 0 10px var(--accent-red);
            animation: tx-blink 0.8s step-end infinite;
        }

        @keyframes tx-blink {
            50% { opacity: 0.2; transform: scale(0.9); }
        }

        .tag-container { 
            display: flex; 
            gap: 15px; 
            justify-content: center; 
            margin-top: 30px; 
        }
        
        .tag { 
            padding: 8px 20px; 
            background: transparent;
            border: 1px solid var(--accent-green); 
            color: var(--accent-green);
            font-size: 0.85rem; 
            transition: all 0.15s ease;
            text-decoration: none;
            cursor: pointer;
        }

        .tag:hover {
            background: var(--accent-green);
            color: var(--bg-black);
            box-shadow: 0 0 20px rgba(82, 255, 0, 0.4);
        }

        /* 顶部扫描线条 */
        .scanner {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 2px;
            background: linear-gradient(90deg, transparent, var(--accent-green), transparent);
            opacity: 0.2;
            animation: scan-move 4s linear infinite;
        }

        @keyframes scan-move {
            0% { top: 0; }
            100% { top: 100%; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="corner top-left"></div>
        <div class="corner top-right"></div>
        <div class="corner bottom-left"></div>
        <div class="corner bottom-right"></div>
        <div class="scanner"></div>

        <div class="sub-header">Chinese Radio Amateur Club</div>
        <h1>BA8BLK</h1>
        
        <div class="data-stream">
            <span>OP: BA8BLK</span>
            <span>LOC: <span id="dynamic-loc">OM21vq</span></span>
            <div class="status-box">
                <div class="tx-dot"></div>
                <span>STATUS: ON AIR</span>
            </div>
        </div>

        <div class="tag-container">
            <a href="/blog" class="tag">BLOG</a>
            <a class="tag">LOGBOOK</a>
            <a href="https://www.qrz.com/db/BA8BLK" target="_blank" class="tag">QRZ.COM</a>
        </div>
    </div>

    <script>
        // 增加一点极客感：让坐标最后两位随机跳动，模拟实时定位偏置
        const locElement = document.getElementById('dynamic-loc');
        const baseLoc = "OM21";
        const chars = "abcdefghijklmnopqrstuvwxyz0123456789";
        
        setInterval(() => {
            let randomTail = chars.charAt(Math.floor(Math.random() * chars.length)) + 
                             chars.charAt(Math.floor(Math.random() * chars.length));
            locElement.innerText = baseLoc + randomTail;
        }, 3000);
    </script>
</body>
</html>