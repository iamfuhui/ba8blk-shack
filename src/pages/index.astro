---
import '../styles/global.css';
---
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BA8BLK // Chinese Amateur Radio Station</title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@100;400;800&display=swap" rel="stylesheet">
    <style>
        /* 1. 模拟 CRT 屏幕颗粒与扫描线 */
        .crt-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), 
                        linear-gradient(90deg, rgba(255, 0, 0, 0.02), rgba(0, 255, 0, 0.01), rgba(0, 0, 255, 0.02));
            background-size: 100% 3px, 3px 100%;
            pointer-events: none;
            z-index: 100;
        }

        /* 2. 核心闪烁动画：模拟电流不稳和荧光粉余辉 */
        @keyframes crt-flicker {
            0% { opacity: 0.98; filter: brightness(1); }
            5% { opacity: 0.95; filter: brightness(1.05); }
            10% { opacity: 0.99; }
            15% { opacity: 0.96; }
            50% { opacity: 1; }
            80% { opacity: 0.98; }
            100% { opacity: 1; }
        }

        /* 3. 文字扫描重影动画：模拟 CRT 电子束扫描时的轻微位移 */
        @keyframes text-scan {
            0%, 100% { text-shadow: 0 0 10px rgba(82, 255, 0, 0.5); }
            33% { text-shadow: 2px 0 2px rgba(255,0,0,0.1), -2px 0 2px rgba(0,0,255,0.1), 0 0 15px rgba(82, 255, 0, 0.6); }
            66% { text-shadow: -1px 0 1px rgba(255,0,0,0.1), 1px 0 1px rgba(0,0,255,0.1), 0 0 12px rgba(82, 255, 0, 0.4); }
        }

        .crt-flicker-effect {
            animation: crt-flicker 0.15s infinite;
        }

        .glow-text {
            animation: text-scan 2s infinite;
        }

        .grid-bg {
            position: fixed;
            inset: 0;
            pointer-events: none;
            opacity: 0.15;
            background-image: 
                linear-gradient(rgba(82, 255, 0, 0.1) 1px, transparent 1px), 
                linear-gradient(90deg, rgba(82, 255, 0, 0.1) 1px, transparent 1px);
            background-size: 32px 32px;
        }
    </style>
</head>
<body class="bg-[#0a0a0c] text-[#52ff00] min-h-screen flex items-center justify-center m-0 overflow-hidden font-['JetBrains_Mono'] crt-flicker-effect">
    
    <div class="crt-overlay"></div>
    <div class="grid-bg"></div>

    <main class="relative z-10 flex flex-col items-center">
        
        <p class="text-[12px] md:text-sm tracking-[0.8em] mb-4 opacity-70 ml-[0.8em] uppercase font-bold text-center">
            Chinese Amateur Radio Station
        </p>
        
        <h1 class="text-[18vw] md:text-[14rem] font-black leading-none tracking-tighter glow-text select-none">
            BA8BLK
        </h1>

        <div class="flex flex-wrap gap-4 md:gap-6 mt-12 justify-center max-w-4xl px-6">
            {[
                { name: "BLOG", href: "/blog" },
                { name: "LOGBOOK", href: "/logbook" },
                { name: "ABOUT", href: "/about" },
                { name: "QRZ.COM", href: "https://www.qrz.com/db/BA8BLK", target: "_blank" }
            ].map((item) => (
                <a 
                    href={item.href} 
                    target={item.target || "_self"}
                    class="px-8 py-2 border border-[#52ff00]/40 text-sm font-bold tracking-[0.2em] transition-all duration-200 
                           hover:bg-[#52ff00] hover:text-black hover:shadow-[0_0_20px_rgba(82,255,0,0.6)] hover:border-[#52ff00]"
                >
                    {item.name}
                </a>
            ))}
        </div>

    </main>

    <div class="fixed bottom-8 left-8 right-8 flex justify-between items-center text-[10px] opacity-20 tracking-[0.3em] font-light">
        <div class="flex items-center gap-2">
            <div class="w-1.5 h-1.5 bg-[#52ff00] rounded-full animate-pulse"></div>
            RX_READY
        </div>
        <div class="hidden md:block text-right">
            GRID: OM21VQ // 14.270 MHZ
        </div>
    </div>

</body>
</html>