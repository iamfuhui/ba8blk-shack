---
import { getCollection } from 'astro:content';
import '../../styles/global.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
---

<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title} // BA8BLK</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Noto+Sans+SC:wght@300;400;700;900&family=JetBrains+Mono:wght@400;700&display=swap" />
</head>
<body class="bg-[#fbfbfb] text-[#171717] antialiased font-['JetBrains_Mono','Noto_Sans_SC']">
    
    <div class="fixed top-0 left-0 w-full h-[2px] bg-black/5 z-50">
        <div class="h-full bg-[#059669] transition-all duration-150" id="progress-bar" style="width: 0%"></div>
    </div>

    <main class="max-w-2xl mx-auto px-6 pt-24 pb-32">
        <nav class="mb-16">
            <a href="/blog" class="text-xs font-bold text-black/30 hover:text-black transition-all flex items-center gap-2">
                &larr; BACK TO ARCHIVE
            </a>
        </nav>

        <header class="mb-16">
            <time class="text-xs font-mono text-[#059669] font-bold tracking-widest block mb-4 uppercase">
                Release: {post.data.pubDate.toLocaleDateString('zh-CN').replace(/\//g, '.')}
            </time>
            <h1 class="text-3xl md:text-4xl font-black text-black leading-tight mb-8 tracking-tighter">
                {post.data.title}
            </h1>
            {post.data.description && (
                <p class="text-lg text-black/40 font-light leading-relaxed border-l-2 border-black/5 pl-6">
                    {post.data.description}
                </p>
            )}
        </header>

        <article class="prose prose-neutral max-w-none 
            prose-headings:text-black prose-headings:font-black prose-headings:tracking-tighter
            prose-p:text-black/80 prose-p:leading-relaxed
            prose-strong:text-black prose-strong:font-bold
            prose-code:text-[#059669] prose-code:bg-black/5 prose-code:px-1 prose-code:rounded
            prose-pre:bg-[#f8f8f8] prose-pre:border prose-pre:border-black/5
            prose-blockquote:border-[#059669] prose-blockquote:bg-transparent prose-blockquote:text-black/60 prose-blockquote:not-italic">
            <Content />
        </article>

        <footer class="mt-32 pt-10 border-t border-black/5 flex justify-between items-center opacity-20 text-[20px] tracking-[0.2em] uppercase">
            <span>Operator: BA8BLK</span>
            <span>Signal out // 73</span>
        </footer>
    </main>

    <script>
        document.addEventListener('scroll', () => {
            const winScroll = document.documentElement.scrollTop;
            const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
            const scrolled = (winScroll / height) * 100;
            const bar = document.getElementById("progress-bar");
            if (bar) bar.style.width = scrolled + "%";
        });
    </script>
</body>
</html>